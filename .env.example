# =============================================================================
# Claude Code Dev Environment — Configuration
# =============================================================================
#
# Copy this file to .env and customize for each instance.
# Docker Compose uses COMPOSE_PROJECT_NAME to namespace all resources
# (containers, volumes, networks) to avoid conflicts when running multiple
# instances simultaneously.
#
# Example setup for second instance:
#   COMPOSE_PROJECT_NAME=trial-claude
#   PORT_BASE=42
# =============================================================================

# -----------------------------------------------------------------------------
# Multi-Instance Configuration (REQUIRED for parallel instances)
# -----------------------------------------------------------------------------

# Docker Compose project name (namespaces containers, volumes, networks)
# Change this for each instance to avoid conflicts
# Default: docker-claude
COMPOSE_PROJECT_NAME=docker-claude

# Port base for host bindings (first 2 digits of 41xxx/42xxx)
# Default 41 = 41xxx ports, use 42 for second instance, 43 for third, etc.
# Example: PORT_BASE=42 → ports become 42300, 42500, 42517, etc.
PORT_BASE=41

# Volume check mode for automated environments
# Options: interactive (default), auto-fresh, auto-adopt, skip
# - interactive: Prompt user when orphan volumes detected (default)
# - auto-fresh: Always create fresh volumes, ignore orphans
# - auto-adopt: Auto-adopt from VOLUME_ADOPT_FROM project
# - skip: Skip all checks (trusted environments only)
VOLUME_CHECK_MODE=interactive

# Source project for auto-adopt mode
# Used when VOLUME_CHECK_MODE=auto-adopt
# Example: VOLUME_ADOPT_FROM=docker-claude
VOLUME_ADOPT_FROM=

# -----------------------------------------------------------------------------
# Container Configuration
# -----------------------------------------------------------------------------

# Username inside the container (default: dev, UID/GID 1000)
DEV_USER=dev

# -----------------------------------------------------------------------------
# Claude Authentication
# -----------------------------------------------------------------------------

# Claude Code API Key
# Set this for headless/API key authentication.
# Leave empty to use OAuth (run 'claude login' inside the container).
ANTHROPIC_API_KEY=

# Anthropic endpoint override (e.g. for proxies or local LLM gateways)
# ANTHROPIC_BASE_URL=

# Model overrides (leave empty to use Claude Code defaults)
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=

# -----------------------------------------------------------------------------
# iOS Development (Host Bind Mount)
# -----------------------------------------------------------------------------
# Path to workspace folder on host for iOS development workflow.
# Used when starting with host-bind override for iOS Simulator debugging.
#
# When enabled, container's /workspace is bind-mounted to this host folder,
# allowing Flutter iOS apps to be built/run on host Xcode + Simulator
# while editing code inside the container.
#
# Usage:
#   mkdir -p ./workspace
#   make host-bind-mobile-up
#
# Default: ./workspace (inside project folder)
HOST_WORKSPACE_PATH=

# -----------------------------------------------------------------------------
# Host Mounts
# -----------------------------------------------------------------------------

# SSH Agent Socket (Mac/Linux only — auto-detected by setup script)
# On Windows, SSH keys are mounted directly from %USERPROFILE%\.ssh
SSH_AUTH_SOCK=

# Host home directory (for mounting .gitconfig)
# Mac/Linux: auto-detected
# Windows: set to your %USERPROFILE% path
HOME=

# Claude Code local marketplace path (absolute path to your marketplace folder)
# Example: /Users/<YOUR_USERNAME>/path/to/your/marketplace
CLAUDE_MARKETPLACE_PATH=

# Windows only: User profile path
# USERPROFILE=C:\Users\YourName